/* Style for unchecked checkboxes */
.wapf-checkboxes input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    border: 2px solid black;
    border-radius: 4px; /* optional: add border-radius for rounded corners */
    width: 20px; /* set the desired width of the checkbox */
    height: 20px; /* set the desired height of the checkbox */
	margin-top: -1px;
	cursor: pointer !important;
}

/* Style for the checkbox label text */
.wapf-checkboxes .wapf-label-text {
    margin-left: 5px; /* optional: add spacing between checkbox and label text */
}

/* Style for checked checkboxes */
.wapf-checkboxes input[type="checkbox"]:checked {
    background-color: black;
    border: 2px solid black;
}

/* Style for the check icon */
.wapf-checkboxes input[type="checkbox"]:checked + .wapf-input-label::before {
    
    display: inline-block;
    font-size: 12px ; /* set the desired size of the checkmark icon */
    color: white;
    margin-right: 5px; /* optional: add spacing between checkmark and label text */
}

.wapf-swatch--image.wapf-checked {
	border: 3px solid black !important;
	border-radius: 0.5vw;
}

