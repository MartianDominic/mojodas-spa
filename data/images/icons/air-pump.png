				<div class="elementor-widget-container">
			
   <style>
    #toggle-button {
      cursor: pointer;
      width: 40px;
      height: 40px;
      transition: transform 0.2s;
    }
    
    
  </style>
</head>

  <svg id="toggle-button" width="48" height="48" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M4 5C3.44772 5 3 5.44772 3 6C3 6.55228 3.44772 7 4 7H20C20.5523 7 21 6.55228 21 6C21 5.44772 20.5523 5 20 5H4ZM7 12C7 11.4477 7.44772 11 8 11H20C20.5523 11 21 11.4477 21 12C21 12.5523 20.5523 13 20 13H8C7.44772 13 7 12.5523 7 12ZM13 18C13 17.4477 13.4477 17 14 17H20C20.5523 17 21 17.4477 21 18C21 18.5523 20.5523 19 20 19H14C13.4477 19 13 18.5523 13 18Z" fill="#ffffff"/>
  </svg>

  <script>
    const toggleButton = document.getElementById("toggle-button");
    let isOpen = false;

    toggleButton.addEventListener("click", () => {
      isOpen = !isOpen;
      toggleButton.style.transform = isOpen ? "rotate(90deg)" : "rotate(0deg)";

      // Change the SVG path based on isOpen state
      if (isOpen) {
        toggleButton.innerHTML = `
          <path d="M12 12L5 5" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M5 12L12 5" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        `;
      } else {
        toggleButton.innerHTML = `
          <path d="M4 5C3.44772 5 3 5.44772 3 6C3 6.55228 3.44772 7 4 7H20C20.5523 7 21 6.55228 21 6C21 5.44772 20.5523 5 20 5H4ZM7 12C7 11.4477 7.44772 11 8 11H20C20.5523 11 21 11.4477 21 12C21 12.5523 20.5523 13 20 13H8C7.44772 13 7 12.5523 7 12ZM13 18C13 17.4477 13.4477 17 14 17H20C20.5523 17 21 17.4477 21 18C21 18.5523 20.5523 19 20 19H14C13.4477 19 13 18.5523 13 18Z" fill="#ffffff"/>
        `;
      }
    });
</script>		</div>
